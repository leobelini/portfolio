---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/out/Layout.astro';
import { formatDate } from '../../utils/date';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime(),
);
---

<Layout
  title="Blog | Leo Belini"
  description="Artigos sobre desenvolvimento, aprendizado e projetos."
>
  <section
    class="relative min-h-screen overflow-hidden px-5 pt-24 pb-20 sm:px-8 md:px-10"
    aria-label="Blog"
  >
    <div
      aria-hidden="true"
      class="pointer-events-none absolute -top-16 -left-8 h-64 w-64 rounded-full bg-lime-500/10 blur-3xl"
    >
    </div>
    <div
      aria-hidden="true"
      class="pointer-events-none absolute top-40 -right-10 h-72 w-72 rounded-full bg-indigo-500/10 blur-3xl"
    >
    </div>

    <div class="relative mx-auto w-full max-w-4xl">
      <header
        class="rounded-2xl border border-white/10 bg-white/3 p-6 shadow-2xl shadow-black/20 backdrop-blur-sm sm:p-8"
      >
        <p class="text-xs tracking-[0.18em] text-gray-400 uppercase">Conteudo</p>
        <h1
          class="primary-text-gradient mt-3 text-3xl leading-tight font-bold sm:text-4xl md:text-5xl"
        >
          Blog
        </h1>
        <p class="mt-5 max-w-2xl text-base leading-relaxed text-gray-300 sm:text-lg">
          Notas praticas sobre codigo, carreira e o que estou construindo.
        </p>
      </header>

      <div class="mt-8 grid gap-4 sm:gap-5">
        {
          posts.map((post) => (
            <a
              href={`/blog/${post.data.slug}`}
              class="group rounded-2xl border border-white/10 bg-black/20 p-5 transition-all duration-300 hover:-translate-y-0.5 hover:border-lime-400/40 hover:bg-black/30 hover:shadow-lg hover:shadow-lime-900/20 sm:p-6"
            >
              <p class="text-xs tracking-[0.16em] text-gray-400 uppercase">
                {formatDate(post.data.pubDate)}
              </p>
              <h2 class="mt-2 text-xl leading-snug font-semibold text-zinc-100 transition-colors duration-300 group-hover:text-lime-300 sm:text-2xl">
                {post.data.title}
              </h2>
              <p class="mt-3 text-sm leading-relaxed text-gray-300 sm:text-base">
                {post.data.description}
              </p>
              <span class="mt-4 inline-flex items-center gap-2 text-sm text-lime-400 transition-colors duration-300 group-hover:text-lime-300">
                Ler artigo
                <span aria-hidden="true">→</span>
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
