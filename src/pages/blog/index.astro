---
import { getCollection } from "astro:content";
import Layout from "../../layouts/out/Layout.astro";
import { createSlug } from "../../utils/strings";

const posts = await getCollection("blog");
---

<Layout>
  <section class="min-h-screen flex pt-24 px-10 sm:px-16 md:px-20 flex-col items-start gap-4" aria-label="Blog">
    <h1 class="text-4xl font-bold primary-text-gradient">Blog</h1>
    <div class="mt-6 w-full gap-8">
      {
        posts.map((post) => (
          <a
            href={`/blog/${post.data.slug}`}
            class="transition-shadow hover:shadow-lg"
          >
            <h2 class="text-2xl font-semibold text-primary">{post.data.title}</h2>
            <p class="mt-2 text-gray-400">{post.data.description}</p>
          </a>
        ))
      }
  </section>
 
</Layout>
