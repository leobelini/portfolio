---
export interface Props {
  selector?: string;
}

const { selector = '[data-experience-years]' } = Astro.props;
---

<script define:vars={{ selector }}>
  const startCareer = 2015;
  const experienceYears = new Date().getFullYear() - startCareer;
  const elements = document.querySelectorAll(selector);

  for (const element of elements) {
    element.textContent = experienceYears.toString();
  }
</script>
