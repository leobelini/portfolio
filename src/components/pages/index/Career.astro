---
import { formatDateRange } from "../../../utils/timeline";
import Container from "../../ui/timeline/Container.astro";
import Item from "../../ui/timeline/Item.astro";
import timelineData from "../../../data/timeline.json";
import type { TimelineItem } from "../../../types/time-line-item";

const timeline: TimelineItem[] = timelineData.map((item) => ({
  ...item,
  date: {
    start: new Date(item.date.start),
    end: item.date.end ? new Date(item.date.end) : null,
  },
}));
---

<div class="flex flex-col items-center">
  <div
    class="h-px w-5/6 bg-indigo-900 mask-alpha mask-r-from-black mask-r-from-80% mask-r-to-transparent mask-l-from-black mask-l-from-80% mask-l-to-transparent"
  >
  </div>
</div>

<section
  class="min-h-screen flex flex-col items-center justify-center relative overflow-hidden px-32 md:px-20 my-20"
  id="career"
>
  <div class="max-w-6xl mx-auto w-full flex flex-col">
    <p class="text-lime-600 text-primary font-medium mb-4 text-lg">
      Trajetória
    </p>
    <h2 class="text-2xl md:text-4xl font-bold tracking-tight mb-6">
      Experiência
      <span class="primary-text-gradient">profissional</span>
    </h2>
  </div>

  <Container>
    {
      timeline.map((item, index) => (
        <Item index={index}>
          <h3 slot="title">
            {item.title}
            {item.date.end === null && (
              <span class="text-sm font-normal bg-indigo-800 px-2 py-0.5 rounded-md">
                Atual
              </span>
            )}
          </h3>
          <p slot="date">{formatDateRange(item.date.start, item.date.end)}</p>
          <div slot="description" set:html={item.description} />
        </Item>
      ))
    }
  </Container>
</section>
