---
import { Image } from 'astro:assets';
import ProfileImg from '../../../assets/profile.jpg';
import { experienceYears } from '../../../data/career';
---

<section
  class="relative flex min-h-[calc(100vh-5rem)] scroll-mt-24 items-center overflow-hidden px-4 py-12 sm:px-6 md:min-h-[calc(100vh-6rem)] md:py-16 lg:px-20 xl:px-32"
  id="hero"
  aria-label="Apresentação"
>
  <div class="hero-light hero-light-1" aria-hidden="true"></div>
  <div class="hero-light hero-light-2" aria-hidden="true"></div>
  <div class="hero-light hero-light-3" aria-hidden="true"></div>
  <div class="mx-auto grid w-full max-w-6xl items-center gap-10 md:grid-cols-[auto_1fr] md:gap-12">
    <div class="order-2 md:order-1">
      <p class="text-primary mb-4 text-base font-medium text-lime-600 sm:text-lg">Olá, eu sou</p>
      <h1 class="mb-6 text-4xl font-bold tracking-tight sm:text-5xl md:text-7xl">
        Leonardo <br /><span class="primary-text-gradient">Siervo Belini</span>
      </h1>
      <p class="mb-8 max-w-lg text-lg leading-relaxed text-gray-400 sm:text-xl">
        Desenvolvedor Full Stack com {experienceYears} anos de experiência construindo soluções digitais
        que fazem a diferença.
      </p>
    </div>

    <div class="order-1 flex justify-center md:order-2">
      <div class="relative">
        <div class="blob-container">
          <div class="blob-shape">
            <Image
              src={ProfileImg}
              alt="Foto de perfil de Leonardo Belini"
              class="blob-image"
              height={320}
              width={320}
              loading="eager"
            />
          </div>
          <div class="blob-glow"></div>
        </div>
      </div>
    </div>
  </div>
</section>
