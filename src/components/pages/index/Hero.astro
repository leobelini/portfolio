---
import { Image } from 'astro:assets';
import ProfileImg from '../../../assets/profile.jpg';
import { experienceYears } from '../../../data/career';
---

<section class="min-h-screen flex items-center relative overflow-hidden px-32 md:px-20" id="hero" aria-label="Apresentação">
    <div class="hero-light hero-light-1" aria-hidden="true"></div>
    <div class="hero-light hero-light-2" aria-hidden="true"></div>
    <div class="hero-light hero-light-3" aria-hidden="true"></div>
    <div class="max-w-6xl mx-auto w-full gap-12 grid items-center md:gap-12 md:grid-cols-[auto_1fr]">
        <div class="order-2 md:order-1">
            <p class="text-lime-600 text-primary font-medium mb-4 text-lg">Olá, eu sou</p>
            <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6">Leonardo <br /><span class="primary-text-gradient">Siervo Belini</span></h1>
            <p class="text-xl text-gray-400 max-w-lg leading-relaxed mb-8">
                Desenvolvedor Full Stack com {experienceYears} anos de experiência construindo
                soluções digitais que fazem a diferença.
            </p>
        </div>
        
        <div class="flex justify-center order-1 md:order-2">
            <div class="relative">
              <div class="blob-container">
                <div class="blob-shape">
                  <Image src={ProfileImg} alt="Foto de perfil de Leonardo Belini" class="blob-image" height={320} width={320} loading="eager" />
                </div>
                <div class="blob-glow"></div>
              </div>
            </div>
        </div>
    </div>
</section>
